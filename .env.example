# LLM Provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=sk-...

# Database
DATABASE_URL=data/memory.db

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Model Fallback Chain
MODEL_CHAIN=openai,claude,local
PRIMARY_MODEL=openai

# Timeouts (seconds)
TOOL_TIMEOUT=10
AGENT_TIMEOUT=30
REQUEST_TIMEOUT=90
LLM_RETRY_INTERVAL=2
